<section class="section-collection">
  <div class="page-width">
    <header class="collection-header">
      <h1 class="collection-title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="collection-description rte">
          {{ collection.description }}
        </div>
      {% endif %}
    </header>

    {% if collection.products.size > 0 %}
      <div class="collection-products-grid">
        {% for product in collection.products %}
          <div class="collection-product-card">
            <a href="{{ product.url }}" class="product-card-link">
              <div class="product-card-image-wrapper">
                {% if product.featured_image %}
                  <img 
                    src="{{ product.featured_image | image_url: width: 400 }}" 
                    alt="{{ product.featured_image.alt | escape }}"
                    class="product-card-image"
                    loading="lazy"
                    width="400"
                    height="{{ 400 | divided_by: product.featured_image.aspect_ratio | round }}"
                  >
                {% else %}
                  <div class="product-card-placeholder"></div>
                {% endif %}
                {% if product.compare_at_price > product.price %}
                  <span class="product-card-badge sale">Sale</span>
                {% endif %}
              </div>
              <div class="product-card-info">
                <p class="product-card-category">{{ product.type }}</p>
                <h3 class="product-card-title">{{ product.title }}</h3>
                <div class="product-card-price">
                  {% if product.compare_at_price > product.price %}
                    <span class="price-sale">{{ product.price | money }}</span>
                    <span class="price-compare">{{ product.compare_at_price | money }}</span>
                  {% else %}
                    <span class="price-regular">{{ product.price | money }}</span>
                  {% endif %}
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="collection-pagination">
          {{ paginate | default_pagination }}
        </nav>
      {% endif %}
    {% else %}
      <p class="collection-empty">{{ 'collections.general.no_matches' | t | default: 'No products found' }}</p>
    {% endif %}
  </div>
</section>

<style>
  .section-collection {
    padding: 40px 0;
  }
  .collection-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .collection-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    color: #1E1B4B;
    margin-bottom: 1rem;
  }
  .collection-description {
    color: #6b7280;
    max-width: 600px;
    margin: 0 auto;
  }
  .collection-products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .collection-product-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px -4px rgba(128, 90, 213, 0.15);
    transition: all 0.5s ease;
  }
  .collection-product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px -10px rgba(55, 48, 163, 0.25);
  }
  .product-card-link {
    text-decoration: none;
    color: inherit;
  }
  .product-card-image-wrapper {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f3f4f6;
  }
  .product-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  .collection-product-card:hover .product-card-image {
    transform: scale(1.1);
  }
  .product-card-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 12px;
    font-size: 0.75rem;
    font-weight: bold;
    border-radius: 9999px;
  }
  .product-card-badge.sale {
    background: #dc2626;
    color: white;
  }
  .product-card-info {
    padding: 16px;
  }
  .product-card-category {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #9ca3af;
    margin-bottom: 4px;
  }
  .product-card-title {
    font-weight: 500;
    color: #1E1B4B;
    margin-bottom: 8px;
    font-size: 1rem;
  }
  .product-card-price .price-sale {
    color: #1E1B4B;
    font-weight: bold;
    font-size: 1.125rem;
  }
  .product-card-price .price-compare {
    text-decoration: line-through;
    color: #9ca3af;
    margin-left: 8px;
    font-size: 0.875rem;
  }
  .product-card-price .price-regular {
    color: #1E1B4B;
    font-weight: bold;
    font-size: 1.125rem;
  }
  .collection-pagination {
    margin-top: 40px;
    text-align: center;
  }
</style>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-collection",
  "settings": []
}
{% endschema %}
