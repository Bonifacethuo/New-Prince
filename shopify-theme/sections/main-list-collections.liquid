<section class="section-list-collections">
  <div class="page-width">
    <header class="collections-header">
      <h1 class="collections-title">{{ 'collections.general.title' | t | default: 'Collections' }}</h1>
    </header>

    <div class="collections-grid">
      {% for collection in collections %}
        {% unless collection.handle == 'frontpage' %}
          <div class="collection-card">
            <a href="{{ collection.url }}" class="collection-card-link">
              <div class="collection-card-image-wrapper">
                {% if collection.image %}
                  <img 
                    src="{{ collection.image | image_url: width: 400 }}" 
                    alt="{{ collection.image.alt | escape }}"
                    class="collection-card-image"
                    loading="lazy"
                  >
                {% elsif collection.products.first and collection.products.first.featured_image %}
                  <img 
                    src="{{ collection.products.first.featured_image | image_url: width: 400 }}" 
                    alt="{{ collection.title | escape }}"
                    class="collection-card-image"
                    loading="lazy"
                  >
                {% else %}
                  <div class="collection-card-placeholder"></div>
                {% endif %}
              </div>
              <div class="collection-card-info">
                <h3 class="collection-card-title">{{ collection.title }}</h3>
                <span class="collection-card-count">{{ collection.products_count }} {{ 'collections.general.products' | t | default: 'products' }}</span>
              </div>
            </a>
          </div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .section-list-collections {
    padding: 40px 0;
  }
  .collections-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .collections-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    color: #1E1B4B;
  }
  .collections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .collection-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px -4px rgba(128, 90, 213, 0.15);
    transition: all 0.5s ease;
  }
  .collection-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px -10px rgba(55, 48, 163, 0.25);
  }
  .collection-card-link {
    text-decoration: none;
    color: inherit;
  }
  .collection-card-image-wrapper {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #f3f4f6;
  }
  .collection-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  .collection-card:hover .collection-card-image {
    transform: scale(1.1);
  }
  .collection-card-info {
    padding: 20px;
    text-align: center;
  }
  .collection-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1E1B4B;
    margin-bottom: 8px;
  }
  .collection-card-count {
    font-size: 0.875rem;
    color: #6b7280;
  }
</style>

{% schema %}
{
  "name": "Collection List",
  "tag": "section",
  "class": "section-list-collections",
  "settings": []
}
{% endschema %}
