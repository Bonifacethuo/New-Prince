<section class="section-product">
  <div class="page-width">
    <div class="product-container">
      <div class="product-media-wrapper">
        {% if product.featured_image %}
          <img 
            src="{{ product.featured_image | image_url: width: 600 }}" 
            alt="{{ product.featured_image.alt | escape }}"
            class="product-featured-image"
            width="600"
            height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
          >
        {% endif %}
      </div>

      <div class="product-info-wrapper">
        <h1 class="product-title">{{ product.title }}</h1>
        
        <div class="product-price">
          {% if product.compare_at_price > product.price %}
            <span class="price-sale">{{ product.price | money }}</span>
            <span class="price-compare">{{ product.compare_at_price | money }}</span>
          {% else %}
            <span class="price-regular">{{ product.price | money }}</span>
          {% endif %}
        </div>

        <div class="product-description rte">
          {{ product.description }}
        </div>

        {% form 'product', product %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          
          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}
              <div class="product-option">
                <label for="Option-{{ option.name | handleize }}">{{ option.name }}</label>
                <select 
                  name="options[{{ option.name | escape }}]" 
                  id="Option-{{ option.name | handleize }}"
                  class="product-variant-select"
                >
                  {% for value in option.values %}
                    <option 
                      value="{{ value | escape }}" 
                      {% if option.selected_value == value %}selected="selected"{% endif %}
                    >
                      {{ value }}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% endfor %}
          {% endunless %}

          <div class="product-quantity">
            <label for="Quantity">{{ 'products.product.quantity.label' | t }}</label>
            <input 
              type="number" 
              id="Quantity" 
              name="quantity" 
              value="1" 
              min="1"
              class="quantity-input"
            >
          </div>

          <button 
            type="submit" 
            name="add" 
            class="product-add-button"
            {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
          >
            {% if product.selected_or_first_available_variant.available %}
              {{ 'products.product.add_to_cart' | t }}
            {% else %}
              {{ 'products.product.sold_out' | t }}
            {% endif %}
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

<style>
  .section-product {
    padding: 40px 0;
  }
  .product-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  @media (max-width: 768px) {
    .product-container {
      grid-template-columns: 1fr;
    }
  }
  .product-featured-image {
    width: 100%;
    height: auto;
    border-radius: 12px;
  }
  .product-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #1E1B4B;
  }
  .product-price {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }
  .price-sale {
    color: #dc2626;
    font-weight: bold;
  }
  .price-compare {
    text-decoration: line-through;
    color: #9ca3af;
    margin-left: 10px;
  }
  .product-description {
    margin-bottom: 1.5rem;
    color: #4b5563;
  }
  .product-option {
    margin-bottom: 1rem;
  }
  .product-option label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }
  .product-variant-select,
  .quantity-input {
    padding: 12px 16px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-size: 1rem;
    width: 100%;
    max-width: 200px;
  }
  .product-quantity {
    margin-bottom: 1.5rem;
  }
  .product-add-button {
    background: linear-gradient(135deg, #D4A843, #c4982f);
    color: #1a1a1a;
    font-weight: 600;
    padding: 14px 40px;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .product-add-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(212, 168, 67, 0.4);
  }
  .product-add-button:disabled {
    background: #9ca3af;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }
</style>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section-product",
  "settings": []
}
{% endschema %}
