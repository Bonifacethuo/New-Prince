{% comment %}
  Prince Shop - Password Page Template
{% endcomment %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #3730A3, #5B21B6);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      margin: 0;
    }
    .password-container {
      max-width: 500px;
      width: 100%;
      text-align: center;
      color: white;
    }
    .password-logo {
      margin-bottom: 32px;
    }
    .password-logo svg {
      width: 64px;
      height: 64px;
      color: #D4A843;
    }
    .password-title {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      margin-bottom: 16px;
    }
    .password-message {
      opacity: 0.9;
      margin-bottom: 32px;
    }
    .password-form {
      background: white;
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 24px;
    }
    .password-form input {
      width: 100%;
      padding: 14px 20px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      margin-bottom: 16px;
      font-size: 1rem;
      box-sizing: border-box;
    }
    .password-form button {
      width: 100%;
      padding: 14px 32px;
      background: linear-gradient(135deg, #D4A843, #c4982f);
      color: #1a1a1a;
      font-weight: 600;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 1rem;
      transition: all 0.3s ease;
    }
    .password-form button:hover {
      transform: translateY(-2px);
      box-shadow: 0 0 30px rgba(212, 168, 67, 0.4);
    }
    .password-footer {
      opacity: 0.7;
      font-size: 0.875rem;
    }
    .password-footer a {
      color: white;
    }
  </style>
</head>
<body>
  <div class="password-container">
    <div class="password-logo">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
      </svg>
    </div>

    <h1 class="password-title">{{ shop.name }}</h1>
    <p class="password-message">{{ shop.password_message }}</p>

    {% form 'storefront_password' %}
      <div class="password-form">
        {{ form.errors | default_errors }}
        <input 
          type="password" 
          name="password" 
          placeholder="{{ 'general.password_page.password_placeholder' | t | default: 'Enter password' }}"
        >
        <button type="submit">
          {{ 'general.password_page.enter' | t | default: 'Enter' }}
        </button>
      </div>
    {% endform %}

    <p class="password-footer">
      {{ 'general.password_page.admin_link_html' | t | default: 'Are you the store owner? <a href=\"/admin\">Log in here</a>' }}
    </p>
  </div>
</body>
</html>
