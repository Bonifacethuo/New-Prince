[
  {
    "name": "theme_info",
    "theme_name": "Prince Shop",
    "theme_version": "1.0.0",
    "theme_author": "Prince Shop",
    "theme_documentation_url": "",
    "theme_support_url": ""
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 150
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32 x 32px .png recommended"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Primary Colors"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary color",
        "default": "#3730A3"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary color",
        "default": "#F8BBD9"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent color (Gold)",
        "default": "#D4A843"
      },
      {
        "type": "header",
        "content": "Background Colors"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#FAF9F7"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Foreground/Text",
        "default": "#1E1B4B"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_header_font",
        "default": "playfair_display_n4",
